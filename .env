# App Configurations
ENVIRONMENT=development
PORT=8000
SECRET_KEY=supersecretjwtkeyforresumeanalyzerappchangeinproduction
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Settings
# SQLite for development: sqlite:///./resume_analyzer.db
# PostgreSQL for production: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///./resume_analyzer.db

# AI API Keys
GEMINI_API_KEY=AQ.Ab8RN6LD_925yPo8shU3OnCVDwFWb1HJM8DHfgLWtLLmNBWieQ
OPENAI_API_KEY=your_openai_api_key_here

# File Storage Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Admin user seeding (Optional, will auto-create on startup if credentials provided)
ADMIN_EMAIL=admin@resumeanalyzer.com
ADMIN_PASSWORD=adminpassword123